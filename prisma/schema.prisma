generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

generator erd {
  provider = "prisma-erd-generator"
  output   = "ERD.svg"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  SITTER
  ADMIN
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum JobStatus {
  OPEN
  WAITING
  FUNDED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  REMOVED
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

model User {
  id                   String                @id @default(cuid())
  email                String                @unique
  password             String
  name                 String
  role                 Role
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  pets                 Pet[]
  sitterProfile        SitterProfile?
  verificationRequests VerificationRequest[]
  jobPosts             JobPost[]             @relation("OwnerJobPosts")
  jobApplications      JobApplication[]      @relation("SitterApplications")
  workProofs           WorkProof[]           @relation("SitterProofs")
}

model Pet {
  id          String    @id @default(cuid())
  name        String
  type        String
  breed       String?
  age         Int?
  description String?
  ownerId     String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  owner       User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  jobPosts    JobPost[]
}

model SitterProfile {
  id                 String             @id @default(cuid())
  userId             String             @unique
  bio                String?
  experience         String?
  resumeUrl          String?
  verificationStatus VerificationStatus @default(PENDING)
  isBanned           Boolean            @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationRequest {
  id           String             @id @default(cuid())
  userId       String
  documentUrl  String?
  note         String?
  status       VerificationStatus @default(PENDING)
  reviewedById String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model JobPost {
  id               String           @id @default(cuid())
  ownerId          String
  petId            String
  title            String
  description      String
  location         String?
  startDate        DateTime
  endDate          DateTime
  paymentAmount    Float
  status           JobStatus        @default(OPEN)
  selectedSitterId String?
  rating           Int?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  owner            User             @relation("OwnerJobPosts", fields: [ownerId], references: [id], onDelete: Cascade)
  pet              Pet              @relation(fields: [petId], references: [id], onDelete: Cascade)
  applications     JobApplication[]
  workProofs       WorkProof[]
}

model JobApplication {
  id        String            @id @default(cuid())
  jobPostId String
  sitterId  String
  message   String?
  status    ApplicationStatus @default(PENDING)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  jobPost   JobPost           @relation(fields: [jobPostId], references: [id], onDelete: Cascade)
  sitter    User              @relation("SitterApplications", fields: [sitterId], references: [id], onDelete: Cascade)

  @@unique([jobPostId, sitterId])
}

model WorkProof {
  id          String   @id @default(cuid())
  jobPostId   String
  sitterId    String
  proofText   String?
  imageUrl    String?
  submittedAt DateTime @default(now())
  jobPost     JobPost  @relation(fields: [jobPostId], references: [id], onDelete: Cascade)
  sitter      User     @relation("SitterProofs", fields: [sitterId], references: [id], onDelete: Cascade)
}
